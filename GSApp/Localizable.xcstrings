    "—": {
      "comment": "A placeholder text for an empty picker selection.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "· %@": {
      "comment": "A small label below the batch name that provides additional context about the batch, such as its location.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "· %@ points": {
      "comment": "A label showing the number of points in a measurement.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "· EAN %@": {
      "comment": "A secondary label displaying the EAN code of a reference.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "#%@": {
      "comment": "A small badge displaying the sequence number of a medication in a list. The argument is the sequence number.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "#%@ · %@": {
      "comment": "A segmented picker option that lists a stock item with its ID and current status.",
