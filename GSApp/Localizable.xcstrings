      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "#%1$@ · %2$@"
          }
        }
      }
    },
    "%@": {
      "comment": "A label showing the number of stock items in a batch. The argument is the count of stock items in the batch.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
