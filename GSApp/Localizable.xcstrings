    "%@ already has %@ stock item(s) in this batch.": {
      "comment": "A message that appears when a user scans a product that is already in stock in a particular batch. The first argument is the display name of the scanned product. The second argument is the count of existing stock items for that product in the batch.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ already has %2$@ stock item(s) in this batch."
          }
        }
      }
    },
    "%@ measurements": {
      "comment": "A label showing the number of measurements in a category. The argument is the count of measurements in the category.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "%@ mm": {
      "comment": "A picker row in the Settings -> Photo view, displaying a focal length in millimeters.",
      "isCommentAutoGenerated": true,
      "localizations": {}
    },
    "%@ point(s)": {
