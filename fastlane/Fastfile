# GS Mobile — Fastlane lanes.
# See https://docs.fastlane.tools for documentation.

default_platform(:ios)

XCODEPROJ = "GSApp.xcodeproj"
SCHEME    = "GSApp"

platform :ios do
  desc "Run unit tests for every local SPM package via `swift test`."
  lane :tests do
    packages = %w[GSCore GSAPIClient GSScanner GSCamera GSLiDAR GSPackshot GSLogistics]
    packages.each do |pkg|
      Dir.chdir("../Packages/#{pkg}") do
        sh("swift test")
      end
    end
  end

  desc "Build a TestFlight beta and upload it to App Store Connect."
  lane :beta do
    # TODO: wire `match` once a code-signing certificate repo exists.
    #       For now we rely on automatic signing — set DEVELOPMENT_TEAM in project.yml first.

    setup_ci if is_ci

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean: true
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Promote the latest TestFlight build to the App Store."
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: true
    )

    deliver(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false
    )
  end
end
