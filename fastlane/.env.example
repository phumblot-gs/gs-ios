# Copy this file to fastlane/.env and fill in real values.
# fastlane/.env is git-ignored.

# Used by `match` (once a code-signing certificate repo is set up).
MATCH_PASSWORD=

# App Store Connect API key — generated at
# https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_KEY_ISSUER_ID=
# Base64-encoded contents of the .p8 file.
APP_STORE_CONNECT_API_KEY_KEY=
